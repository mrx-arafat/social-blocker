else
  export NODE_PATH="/Users/easinarafat/Devs/social-blocker/node_modules/.pnpm/publish-browser-extension@3.0.3/node_modules/publish-browser-extension/bin/node_modules:/Users/easinarafat/Devs/social-blocker/node_modules/.pnpm/publish-browser-extension@3.0.3/node_modules/publish-browser-extension/node_modules:/Users/easinarafat/Devs/social-blocker/node_modules/.pnpm/publish-browser-extension@3.0.3/node_modules:/Users/easinarafat/Devs/social-blocker/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../publish-browser-extension/bin/publish-extension.cjs" "$@"
else
  exec node  "$basedir/../publish-browser-extension/bin/publish-extension.cjs" "$@"
fi
